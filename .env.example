# Copiar a .env.local (no commitear .env.local).
# Tras restaurar dump de producción: usa la URL local y la clave del webservice del BO (o ps_webservice_account).

NEXT_PUBLIC_PRESTASHOP_URL=http://localhost:8080
PRESTASHOP_API_KEY=
# Mismo secreto que CHETTO_HEADLESS_CART_TOKEN en PrestaShop (BO o ps_configuration). En local tras install del módulo suele ser chetto_cart_sync_dev_change_me
PRESTASHOP_CART_SYNC_TOKEN=chetto_cart_sync_dev_change_me
# id_currency en PrestaShop (1 = EUR habitual). Usado al crear carrito vía /api/cart/add
PRESTASHOP_CURRENCY_ID=1

# POST /api/order/create: total TTC vía scripts/cart_order_total.php en el contenedor Docker
PRESTASHOP_DOCKER_CONTAINER=chetto-prestashop
# PRESTASHOP_ORDER_STATE_ID=1

# Opcional: migración tools/prestashop-migration
# PRESTASHOP_SOURCE_BASE_URL=
# PRESTASHOP_SOURCE_API_KEY=
# PRESTASHOP_TARGET_BASE_URL=http://localhost:8080
# PRESTASHOP_TARGET_API_KEY=
